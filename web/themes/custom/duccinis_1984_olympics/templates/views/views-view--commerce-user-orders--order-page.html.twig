{#
/**
 * @file
 * Theme override for the Commerce User Orders view, display: order_page.
 *
 * Adds an archive filter/sort toolbar above the order history table.
 */
#}

{{ attach_library('duccinis_1984_olympics/archive-filter-sort') }}

<div{{ attributes.addClass('view', 'view-' ~ id|clean_class, 'view-id-' ~ id, 'view-display-id-' ~ display_id) }}>
  {{ title_prefix }}
  {{ title_suffix }}

  {% if header %}
    <div class="view-header">
      {{ header }}
    </div>
  {% endif %}

  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}

  {# ── Archive sort toolbar for order history ── #}
  {% include 'duccinis_1984_olympics:archive-controls' with {
    show_sort: true,
    sort_label: 'Sort orders',
    sort_options: [
      { value: 'default', label: 'Default' },
      { value: 'date-desc', label: 'Newest first' },
      { value: 'date-asc', label: 'Oldest first' },
      { value: 'total-desc', label: 'Total: high – low' },
      { value: 'total-asc', label: 'Total: low – high' },
    ],
  } %}

  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}

  {% if rows %}
    <div class="view-content">
      {{ rows }}
    </div>
  {% elseif empty %}
    <div class="view-empty">
      {{ empty }}
    </div>
  {% endif %}

  {% if pager %}
    <div class="pager">
      {{ pager }}
    </div>
  {% endif %}

  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}

  {% if more %}
    {{ more }}
  {% endif %}

  {% if footer %}
    <div class="view-footer">
      {{ footer }}
    </div>
  {% endif %}

  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}
</div>
