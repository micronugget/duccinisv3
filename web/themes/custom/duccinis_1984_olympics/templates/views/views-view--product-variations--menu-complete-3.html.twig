{#
/**
 * @file
 * Theme override for the Product Variations view, display: Menu complete 3.
 *
 * This display uses Bootstrap 5 accordion with pure Twig rendering.
 * The accordion wrapper is created here, and each group becomes an accordion item
 * via the views-view-unformatted template.
 */
#}

{{ attach_library('duccinis_1984_olympics/menu_accordion') }}

{% set accordion_id = accordion_id|default('menu-complete-3-accordion') %}

<div{{ attributes.addClass('view', 'view-' ~ id|clean_class, 'view-id-' ~ id, 'view-display-id-' ~ display_id) }}>
  {{ title_prefix }}
  {{ title_suffix }}

  {% if header %}
    <div class="view-header">
      {{ header }}
    </div>
  {% endif %}

  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}

  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}

  {% if rows %}
    <div class="view-content">
      <div id="{{ accordion_id }}" class="accordion menu-accordion">
        {{ rows }}
      </div>
    </div>
  {% elseif empty %}
    <div class="view-empty">
      {{ empty }}
    </div>
  {% endif %}

  {% if pager %}
    <div class="pager">
      {{ pager }}
    </div>
  {% endif %}

  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}

  {% if more %}
    {{ more }}
  {% endif %}

  {% if footer %}
    <div class="view-footer">
      {{ footer }}
    </div>
  {% endif %}

  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}
</div>
