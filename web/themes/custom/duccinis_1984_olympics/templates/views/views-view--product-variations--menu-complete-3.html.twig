{#
/**
 * @file
 * Theme override for the Product Variations view, display: Menu complete 3.
 *
 * This display uses Bootstrap 5 accordion with pure Twig rendering.
 * The accordion wrapper is created here, and each group becomes an accordion item
 * via the views-view-unformatted template.
 *
 * Includes an archive filter/sort toolbar above the accordion.
 */
#}

{{ attach_library('duccinis_1984_olympics/menu_accordion') }}
{{ attach_library('duccinis_1984_olympics/archive-filter-sort') }}

{% set accordion_id = accordion_id|default('menu-complete-3-accordion') %}

<div{{ attributes.addClass('view', 'view-' ~ id|clean_class, 'view-id-' ~ id, 'view-display-id-' ~ display_id) }}>
  {{ title_prefix }}
  {{ title_suffix }}

  {% if header %}
    <div class="view-header">
      {{ header }}
    </div>
  {% endif %}

  {% if exposed %}
    <div class="view-filters">
      {{ exposed }}
    </div>
  {% endif %}

  {# ── Archive filter/sort toolbar ── #}
  {% include 'duccinis_1984_olympics:archive-controls' with {
    show_filter: true,
    filter_label: 'Category',
    filter_options: [
      { value: 'all', label: 'All Categories' },
      { value: 'pizza', label: 'Pizza' },
      { value: 'homemade-pasta', label: 'Homemade Pasta' },
      { value: 'salad', label: 'Salads' },
      { value: 'fresh-submarines', label: 'Fresh Submarines' },
      { value: 'famous-stromboli', label: 'Famous Stromboli' },
      { value: 'chicken-wings', label: 'Buffalo Wings' },
      { value: 'gyro', label: 'Gyro Special' },
      { value: 'side-orders', label: 'Side Orders' },
      { value: 'desserts', label: 'Desserts' },
      { value: 'beverages', label: 'Beverages' },
      { value: 'specials', label: 'Specials' },
      { value: 'menu-extras', label: 'Menu Extras' },
    ],
    show_sort: true,
    sort_label: 'Sort',
    sort_options: [
      { value: 'default', label: 'Default' },
      { value: 'name-asc', label: 'Name A – Z' },
      { value: 'name-desc', label: 'Name Z – A' },
    ],
  } %}

  {% if attachment_before %}
    <div class="attachment attachment-before">
      {{ attachment_before }}
    </div>
  {% endif %}

  {% if rows %}
    <div class="view-content">
      <div id="{{ accordion_id }}" class="accordion menu-accordion">
        {{ rows }}
      </div>
    </div>
  {% elseif empty %}
    <div class="view-empty">
      {{ empty }}
    </div>
  {% endif %}

  {% if pager %}
    <div class="pager">
      {{ pager }}
    </div>
  {% endif %}

  {% if attachment_after %}
    <div class="attachment attachment-after">
      {{ attachment_after }}
    </div>
  {% endif %}

  {% if more %}
    {{ more }}
  {% endif %}

  {% if footer %}
    <div class="view-footer">
      {{ footer }}
    </div>
  {% endif %}

  {% if feed_icons %}
    <div class="feed-icons">
      {{ feed_icons }}
    </div>
  {% endif %}
</div>
