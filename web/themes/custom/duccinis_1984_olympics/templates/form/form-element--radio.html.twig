{#
/**
 * @file
 * Theme override for a radio form element — with saved payment card support.
 *
 * When card_data is present (a stored payment method), renders a styled card
 * row with brand badge, masked number, and expiry.  The native <input> is kept
 * visually-hidden so the <label> row is the click target; CSS :checked on the
 * input drives the selected state with zero JavaScript.
 *
 * When is_new_card is true, renders a "+ Use a different card" link-style row.
 *
 * All other radios fall through to the standard Radix component.
 *
 * Extra variables added by duccinis_1984_olympics_preprocess_form_element():
 * - card_data: Assoc with brand, last4, expMonth, expYear.
 * - is_new_card: Boolean flag for the new-payment-method option.
 * - element_id: The #id of the hidden radio input (for <label for="..."">).
 *
 * @see duccinis_1984_olympics_preprocess_form_element()
 * @see store_fulfillment_payment_radios_process()
 */
#}
{% if card_data is defined %}
  {#
    Saved card row.
    The visually-hidden radio sits BEFORE the <label> so CSS can use the
    adjacent-sibling :checked selector to drive border/background/checkmark.
  #}
  <div class="saved-card-item">
    {{ children }}
    <label for="{{ element_id }}" class="saved-card">
      <span class="saved-card__brand saved-card__brand--{{ card_data.brand|lower }}">
        {{- card_data.brand|upper -}}
      </span>
      <span class="saved-card__details">
        <span class="saved-card__number">&bull;&bull;&bull;&bull; &bull;&bull;&bull;&bull; &bull;&bull;&bull;&bull; {{ card_data.last4 }}</span>
        <span class="saved-card__expiry">{{ 'Expires'|t }} {{ card_data.expMonth }}/{{ card_data.expYear }}</span>
      </span>
      <span class="saved-card__check" aria-hidden="true">&#10003;</span>
    </label>
  </div>
{% elseif is_new_card is defined %}
  {# "+ Use a different card" link-style option. #}
  <div class="saved-card-item saved-card-item--new">
    {{ children }}
    <label for="{{ element_id }}" class="saved-card__new-link">
      + {{ 'Use a different card'|t }}
    </label>
  </div>
{% else %}
  {# Standard radio — delegate to Radix component. #}
  {% include "radix:form-element--radiocheckbox" %}
{% endif %}
