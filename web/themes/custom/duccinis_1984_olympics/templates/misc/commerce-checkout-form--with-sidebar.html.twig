{#
/**
 * @file
 * Theme override: Bootstrap 5 row/col grid for the Commerce checkout form.
 *
 * Replaces Commerce's custom CSS Grid with Bootstrap's responsive grid so
 * gutters, padding, and breakpoints are handled natively — avoiding conflicts
 * with Commerce's own commerce_checkout.form.css float/padding rules.
 *
 * Issue #29: The primary submit ("Continue to Review") is rendered inside
 * the sidebar card as a full-width branded CTA. The actions region in the
 * footer is kept visible for any secondary actions (e.g. "Back" links) but
 * the 'next' key is excluded from it to avoid a duplicate submit button.
 *
 * Available variables:
 * - form: The form.
 */
#}
<div class="layout-checkout-form clearfix">

  {# ── Issue #31: Checkout progress bar ── #}
  {% if checkout_progress_steps %}
    <nav class="checkout-progress" aria-label="{{ 'Checkout progress'|t }}">
      {% for step in checkout_progress_steps %}
        {%- if step.url %}
          <a href="{{ step.url }}"
             class="step{{ step.state ? ' ' ~ step.state : '' }}">
            {{- step.label -}}
          </a>
        {%- elseif step.state == 'active' %}
          <div class="step active" aria-current="step">{{- step.label -}}</div>
        {%- else %}
          <div class="step" aria-disabled="true">{{- step.label -}}</div>
        {%- endif %}
      {% endfor %}
    </nav>
  {% endif %}

  <div class="row gy-4 align-items-start">
    <div class="col-12 col-lg-8 layout-region layout-region-checkout-main">
      {{ form|without('sidebar', 'actions') }}
    </div>
    <div class="col-12 col-lg-4 layout-region layout-region-checkout-secondary">
      {{ form.sidebar }}
      {# ── Issue #29: Branded "Continue to Review" CTA inside the card ── #}
      {% if form.actions.next is defined %}
        <div class="cta-section">
          {{ form.actions.next }}
        </div>
      {% endif %}
    </div>
  </div>
  {# Footer: render any secondary actions (Back link) but skip 'next' so   #}
  {# the submit button only appears once, in the sidebar CTA above.        #}
  <div class="layout-region layout-region-checkout-footer">
    {{ form.actions|without('next') }}
  </div>
</div>
