{#
/**
 * @file
 * Menu accordion rendering for Product Variations: Menu complete 2.
 *
 * Expects Views style grouping to be enabled so `rows` is a list of groups.
 * Each group item contains:
 * - title: The group title (Product Type label).
 * - rows: Row render arrays for variations within that type.
 */
#}

{{ attach_library('duccinis_theme/menu_accordion') }}

{% set accordion_id = 'menu-complete-2-accordion' %}

{#
  IMPORTANT: When Views grouping is enabled, this template can be invoked
  multiple times (nested grouping). In those nested calls, `title` is set.
  We must NOT output a full accordion wrapper for nested groups, otherwise
  we create repeated accordions and duplicate IDs.
#}

{% if title %}
  {# Nested group (e.g., Product Title within a Type): render heading + rows. #}
  <div class="product-group">
    <h3 class="product-title">{{ title }}</h3>
  </div>

  {% for row in rows %}
    <div{{ row.attributes.addClass('menu-variation-row') }}>
      {{ row.content }}
    </div>
  {% endfor %}
{% else %}
<div id="{{ accordion_id }}" class="accordion menu-accordion">
  {#
    Drupal Views `views-view-unformatted.html.twig` can receive either:
    - Ungrouped rows: `rows` is a list of row items (`row.content`).
    - Grouped rows: `rows` is a map of `group_title => group_rows`.
      When multiple grouping fields are configured, `group_rows` can itself be
      another map (nested groups).

    This template supports:
    - Ungrouped output (single accordion group)
    - One-level grouping (Type)
    - Two-level grouping (Type -> Product)
  #}

  {% if rows is empty %}
    {# Nothing to render. #}
  {% elseif rows|first is iterable and rows|first.content is defined %}
    {#
      Ungrouped at the top-level. This should not normally happen for
      `menu_complete_2` (we expect grouped output), but we keep a safe fallback.
    #}
    {% for row in rows %}
      <div{{ row.attributes.addClass('menu-variation-row') }}>
        {{ row.content }}
      </div>
    {% endfor %}
  {% else %}
    {# Grouped (one or two levels). #}
    {% for type_title, type_rows in rows %}
      {% set type_title_text = type_title|render|striptags|trim %}
      {% set type_key = type_title_text ? type_title_text|clean_class : 'type-' ~ loop.index %}
      {% set heading_id = accordion_id ~ '--heading--' ~ type_key %}
      {% set collapse_id = accordion_id ~ '--collapse--' ~ type_key %}

      <div class="accordion-item menu-accordion__item" id="product-type-{{ type_key }}">
        <h2 class="accordion-header menu-accordion__header" id="{{ heading_id }}">
          <button
            class="accordion-button collapsed menu-accordion__button"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#{{ collapse_id }}"
            aria-expanded="false"
            aria-controls="{{ collapse_id }}"
          >
            {{ type_title }}
          </button>
        </h2>

        <div
          id="{{ collapse_id }}"
          class="accordion-collapse collapse menu-accordion__collapse"
          aria-labelledby="{{ heading_id }}"
          data-bs-parent="#{{ accordion_id }}"
        >
          <div class="accordion-body menu-accordion__body">
            {#
              Delegate rendering of each subgroup (Product Title) to Views by
              printing the subgroup render arrays. This will invoke this same
              template again, but with `title` set, so it will *not* create a
              nested accordion.
            #}
            {{ type_rows }}
          </div>
        </div>
      </div>
    {% endfor %}
  {% endif %}
</div>
{% endif %}
