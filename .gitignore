# Ignore directories generated by Composer
/drush/contrib/
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Ignore sensitive information
/web/sites/*/settings.php
/web/sites/*/settings.local.php
/web/sites/*/settings.ddev.php
/web/sites/default/settings.ddev.php

# Database dumps — never commit these
*.sql
*.sql.gz
*.dump

# Private key / certificate files
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# Ignore Drupal's file directory
/web/sites/*/files/

# Ignore SimpleTest multi-site environment
/web/sites/simpletest

# Ignore files generated by common IDEs
/.idea/
/.vscode/
/.ddev/

# Ignore .env files as they are personal
/.env

# Customizations
web/sites/default/development.services.yml
backup*
drush/sites/
drush/sites/examples.tar.xz
drush/*
web/sites/default/services.yml
web/sites/default/private/.htaccess
web/sites/default/private/tmp/
backup*
databasebackup.sql
]*
node_modules
tests/Nightwatch/reports/

# Binary installers and packages
*.deb
*.rpm
*.exe
*.dmg

# Debug artifact directories
/output/
/output2/
/output3/
/logs/

# Log files
*.log

# PHPUnit cache
.phpunit.cache/

# VS Code workspace files
*.code-workspace
